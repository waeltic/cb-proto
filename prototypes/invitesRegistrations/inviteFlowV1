            In production this screen would show only the options that are really available for this invite.
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block bg-slate-900">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(255,255,255,0.16),_transparent_40%),linear-gradient(135deg,#0f172a,#334155)]"></div>
      </div>
    </section>

    <!-- SCREEN 2A SSO -->
    <section id="screen-sso" class="screen hidden min-h-[calc(100vh-73px)] grid grid-cols-1 lg:grid-cols-2 bg-white">
