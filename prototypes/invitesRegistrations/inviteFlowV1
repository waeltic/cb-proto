            <div class="h-px flex-1 bg-slate-200"></div>
            <div class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-200 text-slate-500">3</div>
            <div>Complete</div>
          </div>

          <div class="text-xs font-medium uppercase tracking-wide text-slate-400">Access setup</div>
          <h2 class="mt-3 text-4xl font-semibold leading-tight text-slate-900">How should this access be connected?</h2>
          <p class="mt-4 max-w-lg text-sm leading-6 text-slate-600">Choose whether this account should be linked directly to Leana Winter or to a parent / guardian with access to the profile.</p>

          <div class="mt-8 space-y-3">
            <button onclick="setPath('self'); go('screen-player-form')" class="w-full rounded-2xl border border-slate-200 bg-white p-5 text-left hover:border-slate-300 hover:bg-slate-50">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="text-lg font-medium">Self access</div>
                  <div class="mt-1 text-sm text-slate-500">This account belongs to Leana Winter directly.</div>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">Direct link</span>
              </div>
            </button>

            <button onclick="setPath('parent'); go('screen-parent-form')" class="w-full rounded-2xl border border-slate-200 bg-white p-5 text-left hover:border-slate-300 hover:bg-slate-50">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="text-lg font-medium">Parent / guardian access</div>
                  <div class="mt-1 text-sm text-slate-500">This account belongs to a parent or guardian who should be linked to Leana Winter.</div>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">Linked access</span>
              </div>
