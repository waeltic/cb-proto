            </div>

            <div>
              <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-500">Continue with email</label>
              <input id="emailInput" value="claudia+5555@pixel-plus.ch" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 w-full" />
              <div class="mt-3 grid grid-cols-2 gap-3">
