            <button onclick="go('screen-start')" class="text-sm text-slate-400 hover:text-slate-600">← Back</button>
            <div class="text-2xl font-semibold tracking-tight text-slate-900">coachbetter</div>
            <div class="text-xs text-slate-500">EN · Help</div>
          </div>

          <div class="text-xs font-medium uppercase tracking-wide text-slate-400">Sign in</div>
