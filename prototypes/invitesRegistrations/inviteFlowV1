<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invite Flow Clickable Prototype</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 text-slate-900 font-sans">
  <div class="min-h-screen">
    <div class="flex items-center justify-between px-6 py-4 bg-white border-b border-slate-200">
      <div>
        <h1 class="text-lg font-semibold">Invite flow clickable prototype</h1>
        <p class="text-sm text-slate-500">Prototype for self / parent access, data confirmation, legal step, and completion.</p>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="resetFlow()" class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Reset</button>
      </div>
    </div>

    <!-- SCREEN 1 -->
    <section id="screen-start" class="screen min-h-[calc(100vh-73px)] grid grid-cols-1 lg:grid-cols-2 bg-white">
      <div class="flex items-center justify-center p-10 lg:p-14">
        <div class="max-w-lg w-full">
          <div class="mb-10 flex items-center justify-between">
            <div class="text-2xl font-semibold tracking-tight text-slate-900">coachbetter</div>
            <div class="text-xs text-slate-500">EN · Help</div>
          </div>

          <div class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700 border border-emerald-100">
            Invitation from Sportfreunde Burkhardsfelden e.V.
          </div>

          <h2 class="mt-6 text-4xl font-semibold leading-tight text-slate-900">
            Join Leana Winter’s club access
          </h2>

          <p class="mt-5 text-base leading-7 text-slate-600">
            Sportfreunde Burkhardsfelden e.V. invited you to continue the access setup for <span class="font-medium text-slate-800">Leana Winter</span>.
          </p>

          <p class="mt-3 text-sm leading-6 text-slate-500">
            Sign in with your club account or continue with email. We’ll guide you through the remaining steps afterwards.
          </p>

          <div class="mt-8 space-y-4">
            <button onclick="go('screen-auth')" class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-medium text-white hover:bg-emerald-700">
              Continue
            </button>
          </div>

          <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
            <div class="text-sm font-medium text-slate-800">What happens next?</div>
            <div class="mt-2 text-sm leading-6 text-slate-600">
              First you sign in or create an account. After that, we’ll confirm whether the access should be connected directly to Leana Winter or to a parent / guardian.
            </div>
          </div>

          <div class="mt-8 text-xs leading-5 text-slate-400">
            Not the right person or having trouble signing in? Please contact Sportfreunde Burkhardsfelden e.V.
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block bg-slate-900">
        <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-700"></div>
        <div class="absolute inset-0 flex items-center justify-center p-12">
          <div class="w-full max-w-lg rounded-[2rem] border border-white/10 bg-white/10 p-8 backdrop-blur-sm">
            <div class="aspect-[4/3] rounded-[1.5rem] border border-white/10 bg-gradient-to-br from-slate-300/10 to-white/5 flex items-center justify-center">
              <div class="h-40 w-40 rounded-[2rem] bg-white/90 flex items-center justify-center shadow-2xl">
                <div class="text-5xl font-bold tracking-tight text-red-600">SFB</div>
              </div>
            </div>
            <div class="mt-6 text-center text-sm text-white/80">
              Secure access provided through Coachbetter.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SCREEN 2 AUTH -->
