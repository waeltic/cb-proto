<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Birthdate Missing Prototype</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
  <div class="min-h-screen flex">
    <aside class="w-64 bg-slate-950 text-white hidden md:flex flex-col">
      <div class="px-6 py-5 border-b border-slate-800">
        <div class="text-lg font-semibold">CoachBetter</div>
        <div class="text-xs text-slate-400 mt-1">Club Admin</div>
      </div>
      <nav class="p-4 space-y-1 text-sm">
        <a class="block px-3 py-2 rounded-lg bg-slate-800" href="#">Dashboard</a>
        <a class="block px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-800" href="#">Teams</a>
        <a class="block px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-800" href="#">Members</a>
        <a class="block px-3 py-2 rounded-lg text-slate-300 hover:bg-slate-800" href="#">Settings</a>
      </nav>
    </aside>

    <main class="flex-1">
      <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between">
        <div>
          <h1 class="text-xl font-semibold">Dashboard</h1>
          <p class="text-sm text-slate-500">Welcome back, Claudia</p>
        </div>
        <button onclick="openIntro()" class="text-sm rounded-lg border border-slate-300 px-4 py-2 hover:bg-slate-50">Show popup again</button>
      </header>

      <div class="p-6 max-w-6xl mx-auto space-y-6">
        <section id="banner" class="hidden rounded-xl border border-amber-300 bg-amber-50 p-4 shadow-sm">
          <div class="flex gap-3">
            <div class="h-9 w-9 rounded-full bg-amber-100 flex items-center justify-center text-amber-700 font-bold">!</div>
            <div class="flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h2 class="font-semibold text-amber-950">Birth dates missing</h2>
                  <p class="text-sm text-amber-900 mt-1">3 profiles are currently treated as minors because no birth date is available.</p>
                </div>
                <button onclick="openForm()" class="shrink-0 rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700">Review birth dates</button>
              </div>
            </div>
          </div>
        </section>

        <section class="grid md:grid-cols-3 gap-5">
          <div class="rounded-xl bg-white border border-slate-200 p-5 shadow-sm">
            <div class="text-sm text-slate-500">Active members</div>
            <div class="text-3xl font-semibold mt-2">421</div>
          </div>
          <div class="rounded-xl bg-white border border-slate-200 p-5 shadow-sm">
            <div class="text-sm text-slate-500">Teams</div>
            <div class="text-3xl font-semibold mt-2">28</div>
          </div>
          <div class="rounded-xl bg-white border border-slate-200 p-5 shadow-sm">
            <div class="text-sm text-slate-500">Open tasks</div>
            <div class="text-3xl font-semibold mt-2">7</div>
          </div>
        </section>

        <section class="rounded-xl bg-white border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
            <h2 class="font-semibold">Profiles needing review</h2>
            <span class="text-xs rounded-full bg-red-50 text-red-700 px-2.5 py-1 border border-red-200">Minor role applied by default</span>
          </div>
          <div class="divide-y divide-slate-100">
            <div class="px-5 py-4 flex items-center justify-between">
              <div>
                <div class="font-medium">Claudia Wälti</div>
                <div class="text-sm text-slate-500">Your profile · Birth date missing</div>
              </div>
              <span class="text-sm text-red-700">Currently treated as Minor</span>
            </div>
            <div class="px-5 py-4 flex items-center justify-between">
              <div>
                <div class="font-medium">Max Muster</div>
                <div class="text-sm text-slate-500">Child relation · Birth date missing</div>
              </div>
              <span class="text-sm text-red-700">Parent access cannot be age-verified</span>
            </div>
            <div class="px-5 py-4 flex items-center justify-between">
              <div>
                <div class="font-medium">Emma Muster</div>
                <div class="text-sm text-slate-500">Child relation · Birth date missing</div>
              </div>
              <span class="text-sm text-red-700">Parent access cannot be age-verified</span>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div id="overlay" class="fixed inset-0 hidden items-center justify-center bg-slate-900/60 p-4 z-50">
    <div id="introModal" class="w-full max-w-xl rounded-2xl bg-white shadow-2xl overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-200 flex items-start gap-4">
        <div class="h-11 w-11 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center font-bold text-xl">!</div>
        <div>
          <h2 class="text-xl font-semibold">Birth date required</h2>
          <p class="text-sm text-slate-500 mt-1">We could not determine the age for you or linked persons.</p>
        </div>
      </div>
      <div class="px-6 py-5 space-y-5">
        <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-sm text-slate-700">
          Until a birth date is provided, these profiles will be treated as minors for safety reasons. This may affect roles, permissions, communication features and parent/guardian access.
        </div>
        <div>
          <div class="text-sm font-medium mb-3">Missing birth dates</div>
          <div class="space-y-2">
            <div class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2"><span>Claudia Wälti</span><span class="text-xs text-red-700 bg-red-50 border border-red-200 px-2 py-1 rounded-full">Minor applied</span></div>
            <div class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2"><span>Max Muster <span class="text-slate-400">Child</span></span><span class="text-xs text-red-700 bg-red-50 border border-red-200 px-2 py-1 rounded-full">Not verified</span></div>
            <div class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2"><span>Emma Muster <span class="text-slate-400">Child</span></span><span class="text-xs text-red-700 bg-red-50 border border-red-200 px-2 py-1 rounded-full">Not verified</span></div>
          </div>
        </div>
      </div>
      <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
        <button onclick="later()" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium hover:bg-white">Later</button>
        <button onclick="openForm()" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Review birth dates</button>
      </div>
    </div>

    <div id="formModal" class="hidden w-full max-w-2xl rounded-2xl bg-white shadow-2xl overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-200">
        <h2 class="text-xl font-semibold">Complete birth dates</h2>
        <p class="text-sm text-slate-500 mt-1">Please provide the missing birth dates below.</p>
      </div>
      <div class="px-6 py-5 space-y-6">
        <section>
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-3">Your profile</h3>
          <label class="block">
            <span class="text-sm font-medium">Claudia Wälti</span>
            <input type="date" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-slate-900" />
          </label>
        </section>
        <section>
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-3">Children</h3>
          <div class="grid md:grid-cols-2 gap-4">
            <label class="block rounded-xl border border-slate-200 p-4">
              <span class="text-sm font-medium">Max Muster</span>
              <span class="block text-xs text-slate-500 mt-0.5">Child relation</span>
              <input type="date" class="mt-3 w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-slate-900" />
            </label>
            <label class="block rounded-xl border border-slate-200 p-4">
              <span class="text-sm font-medium">Emma Muster</span>
              <span class="block text-xs text-slate-500 mt-0.5">Child relation</span>
              <input type="date" class="mt-3 w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-slate-900" />
            </label>
          </div>
        </section>
        <div class="rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-900">
          Missing birth dates result in automatic Minor status until the age can be verified.
        </div>
      </div>
      <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex justify-between gap-3">
        <button onclick="openIntro()" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium hover:bg-white">Back</button>
        <div class="flex gap-3">
          <button onclick="later()" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium hover:bg-white">Cancel</button>
          <button onclick="saveDone()" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Save changes</button>
        </div>
      </div>
    </div>

    <div id="successModal" class="hidden w-full max-w-md rounded-2xl bg-white shadow-2xl overflow-hidden">
      <div class="px-6 py-8 text-center">
        <div class="mx-auto h-12 w-12 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xl font-bold">✓</div>
        <h2 class="text-xl font-semibold mt-4">Birth dates saved</h2>
        <p class="text-sm text-slate-500 mt-2">The profiles can now be checked against the minor protection rules.</p>
        <button onclick="closeAll()" class="mt-6 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Done</button>
      </div>
    </div>
  </div>

  <script>
    const overlay = document.getElementById('overlay');
    const introModal = document.getElementById('introModal');
    const formModal = document.getElementById('formModal');
    const successModal = document.getElementById('successModal');
    const banner = document.getElementById('banner');

    function showOverlay() { overlay.classList.remove('hidden'); overlay.classList.add('flex'); }
    function hideModals() { introModal.classList.add('hidden'); formModal.classList.add('hidden'); successModal.classList.add('hidden'); }
    function openIntro() { showOverlay(); hideModals(); introModal.classList.remove('hidden'); }
    function openForm() { showOverlay(); hideModals(); formModal.classList.remove('hidden'); }
    function later() { closeAll(); banner.classList.remove('hidden'); }
    function saveDone() { hideModals(); successModal.classList.remove('hidden'); banner.classList.add('hidden'); }
    function closeAll() { overlay.classList.add('hidden'); overlay.classList.remove('flex'); hideModals(); }

    window.addEventListener('load', openIntro);
  </script>
</body>
</html>
