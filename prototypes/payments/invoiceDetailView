<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CoachBetter – Invoice detail (View / Edit)</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 text-gray-900">
  <div class="max-w-6xl mx-auto px-6 py-8">

    <!-- Top controls (demo) -->
    <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
      <div class="text-sm text-gray-600">
        Prototype: Invoice detail view + edit (Once off / Installments / Subscription)
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <select id="demoFlow" class="px-3 py-2 text-sm rounded-lg border bg-white" onchange="setFlow(this.value)">
          <option value="once">Once off</option>
          <option value="inst" selected>Installments</option>
          <option value="sub">Subscription</option>
        </select>

        <select id="demoStatus" class="px-3 py-2 text-sm rounded-lg border bg-white" onchange="setStatus(this.value)">
          <option value="open" selected>Open</option>
          <option value="partial">Partially paid</option>
          <option value="paid">Paid</option>
          <option value="sepa">In SEPA file</option>
          <option value="refunded">Refunded</option>
          <option value="cancelled">Cancelled</option>
        </select>

        <div class="inline-flex rounded-xl border bg-gray-50 p-1">
          <button id="btnView" class="px-3 py-2 text-sm rounded-lg bg-white shadow-sm border border-gray-200" onclick="setMode('view')">View</button>
          <button id="btnEdit" class="px-3 py-2 text-sm rounded-lg text-gray-700 hover:bg-white/60" onclick="setMode('edit')">Edit</button>
        </div>

        <button id="btnSave" class="hidden px-3 py-2 text-sm rounded-lg bg-blue-600 text-white hover:bg-blue-700" onclick="toast('Saved (dummy)')">Save</button>
        <button id="btnCancel" class="hidden px-3 py-2 text-sm rounded-lg border bg-white hover:bg-gray-50" onclick="toast('Cancelled changes (dummy)')">Cancel</button>
      </div>
    </div>

    <!-- Header (calm, document-like) -->
    <header class="bg-white border rounded-xl shadow-sm px-6 py-5">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
        <div class="min-w-0">
          <h1 class="text-lg font-semibold text-gray-900 truncate">
            <span id="hPerson">Kurz Iris</span>
          </h1>

          <div class="mt-1 text-sm text-gray-700 flex flex-wrap items-center gap-x-2 gap-y-1">
            <span class="text-gray-500">Invoice</span>
            <span class="font-medium" id="hInvoiceId">COACH-00000386-1</span>
            <span class="text-gray-300">·</span>
            <span class="font-medium" id="hProduct">Membership fee 2026</span>
            <span class="text-gray-300">·</span>
            <span class="text-gray-700" id="hFlowMeta">Installment 1/3</span>

            <button id="btnViewSchedule" class="hidden text-[11px] text-blue-700 hover:text-blue-800 ml-1" onclick="openSchedule()">
              View schedule
            </button>
          </div>

          <div class="mt-2 text-[11px] text-gray-500 flex flex-wrap items-center gap-x-2 gap-y-1">
            <span>Invoice date <span class="font-medium text-gray-700" id="hInvoiceDate">10.12.2025</span></span>
            <span class="text-gray-300">·</span>
            <span>Due date <span class="font-medium text-gray-700" id="hDueDate">12.02.2026</span></span>
          </div>
        </div>

        <div class="flex items-start gap-4 justify-between lg:justify-end">
          <div class="text-right">
            <div class="text-[11px] text-gray-500">Total</div>
            <div class="text-2xl font-semibold text-gray-900" id="hTotal">CHF 5’015.92</div>

            <div class="mt-1 text-[11px] text-gray-500">
              Paid <span class="font-medium text-gray-700" id="hPaid">CHF 0.00</span>
              <span class="text-gray-300 mx-2">·</span>
              Open <span class="font-medium text-gray-700" id="hOpen">CHF 5’015.92</span>
            </div>
          </div>

          <div class="flex flex-col items-end gap-2 shrink-0">
            <span id="hStatusBadge" class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-medium bg-yellow-50 text-yellow-700">
              Open
            </span>
            <button class="px-3 py-2 text-sm rounded-lg border bg-white hover:bg-gray-50" onclick="toast('Download PDF (dummy)')">Download PDF</button>
          </div>
        </div>
      </div>

      <!-- slim hint area (only when needed) -->
      <div id="headerHint" class="hidden mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
        <div class="text-sm font-semibold text-amber-900" id="headerHintTitle">Limited editing</div>
        <div class="text-sm text-amber-800 mt-1" id="headerHintText">This invoice has transactions or is included in a SEPA file. Some fields are locked.</div>
      </div>
    </header>

    <!-- Main layout -->
    <div class="mt-6 bg-white border rounded-xl shadow-sm">
      <div class="px-6 py-6 space-y-10">

        <!-- Recipient & billing -->
        <section>
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-xs font-semibold text-gray-800">Recipient & billing</div>
              <div class="text-[11px] text-gray-500 mt-1">Name, address and member ID. Billing contact contains the email recipients.</div>
            </div>
            <button class="text-sm text-gray-600 hover:text-gray-900" onclick="toast('Open profile (dummy)')">Open profile</button>
          </div>

          <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Recipient -->
            <div class="space-y-2">
              <div class="text-[11px] uppercase tracking-wide text-gray-500">Recipient</div>

              <!-- view -->
              <div class="cbView">
                <div class="text-sm font-medium text-gray-900" id="vRecipientName">Kurz Iris</div>
                <div class="text-sm text-gray-700 whitespace-pre-line" id="vRecipientAddress">Feldweg 500
8880 Mönseringen (Schweiz)</div>
                <div class="text-[11px] text-gray-500 mt-1">Member ID: <span class="font-medium text-gray-700" id="vMemberId">567789</span></div>
              </div>

              <!-- edit -->
              <div class="cbEdit hidden space-y-3">
                <div>
                  <label class="text-xs text-gray-500">Recipient name</label>
                  <input id="eRecipientName" class="mt-1 w-full border rounded-lg px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500" value="Kurz Iris">
                </div>
                <div>
                  <label class="text-xs text-gray-500">Recipient address</label>
                  <textarea id="eRecipientAddress" rows="3" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500">Feldweg 500
8880 Mönseringen (Schweiz)</textarea>
                </div>
                <div>
                  <label class="text-xs text-gray-500">Member ID</label>
                  <input id="eMemberId" class="mt-1 w-full border rounded-lg px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500" value="567789">
                </div>
              </div>
            </div>

            <!-- Billing contact -->
            <div class="space-y-2">
              <div class="text-[11px] uppercase tracking-wide text-gray-500">Billing contact</div>

              <!-- view -->
              <div class="cbView">
                <div class="text-sm font-medium text-gray-900" id="vBillName">Blumer Andreas</div>
                <div class="text-sm text-gray-700" id="vBillEmails">blumer@club.ch</div>
                <div class="text-[11px] text-gray-500 mt-1" id="vBillEmailsMore">+ 2 more emails</div>
              </div>

              <!-- edit -->
              <div class="cbEdit hidden space-y-3">
                <div>
                  <label class="text-xs text-gray-500">Billing contact name</label>
                  <input id="eBillName" class="mt-1 w-full border rounded-lg px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500" value="Blumer Andreas">
                </div>
                <div>
                  <label class="text-xs text-gray-500">Billing emails</label>
                  <textarea id="eBillEmails" rows="3" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500">blumer@club.ch
tester@tester.ch
tester2@tester.ch</textarea>
                  <div id="billWarn" class="hidden mt-2 text-sm text-amber-900 border border-amber-200 bg-amber-50 rounded-lg px-3 py-2">
                    Missing billing email(s) may prevent notifications.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Details (Payment method + optional reference, compact) -->
        <section class="border-t pt-8">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-xs font-semibold text-gray-800">Details</div>
              <div class="text-[11px] text-gray-500 mt-1">Keep this compact. Payment method is shown on the PDF.</div>
            </div>
          </div>

          <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Payment method -->
            <div class="space-y-2">
              <div class="text-[11px] text-gray-500">Payment method</div>

              <div class="cbView text-sm font-medium text-gray-900" id="vPayMethod">Bank transfer</div>

              <div class="cbEdit hidden space-y-3">
                <select id="ePayMethod" class="w-full border rounded-lg px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500" onchange="onPayMethodChanged()">
                  <option value="bank" selected>Bank transfer</option>
                  <option value="sepa">SEPA direct debit</option>
                  <option value="cash">Cash</option>
                  <option value="psp">Card / PSP</option>
                </select>

                <div id="applyScopeWrap" class="hidden">
                  <label class="text-xs text-gray-500">Apply change to</label>
                  <select id="eApplyScope" class="mt-1 w-full border rounded-lg px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500">
                    <option value="this" selected>This invoice only</option>
                    <option value="future">All future invoices</option>
                  </select>
                  <p class="mt-2 text-[11px] text-gray-500">Only available for installments/subscriptions.</p>
                </div>

                <div id="payLockHint" class="hidden text-sm text-amber-900 border border-amber-200 bg-amber-50 rounded-lg px-3 py-2">
                  Payment method is locked due to status / transactions / SEPA file.
                </div>
              </div>
            </div>

            <!-- Optional reference placeholder (hidden if empty) -->
            <div class="space-y-2">
              <div class="text-[11px] text-gray-500">Reference</div>
              <div class="cbView text-sm text-gray-700" id="vReference">—</div>

              <div class="cbEdit hidden">
                <input id="eReference" class="w-full border rounded-lg px-3 py-2 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500" placeholder="(optional)" value="">
                <p class="mt-2 text-[11px] text-gray-500">Reserved for future bank matching (QR / creditor reference).</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Line items + totals (no quantity) -->
        <section class="border-t pt-8">
          <div class="flex items-center justify-between gap-3">
            <div>
              <div class="text-xs font-semibold text-gray-800">Line items</div>
              <div class="text-[11px] text-gray-500 mt-1">No quantity for now. Tax is shown only in totals.</div>
            </div>
            <button class="cbEdit hidden px-3 py-2 text-sm rounded-lg border bg-white hover:bg-gray-50" onclick="toast('Add item (dummy)')">Add item</button>
          </div>

          <div class="mt-4 overflow-hidden">
            <table class="w-full text-sm">
              <thead class="text-xs text-gray-500 border-b">
                <tr>
                  <th class="text-left py-2 font-medium">Item</th>
                  <th class="text-right py-2 font-medium">Discount</th>
                  <th class="text-right py-2 font-medium">Total</th>
                  <th class="cbEdit hidden text-right py-2 font-medium">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y" id="itemsBody">
                <tr>
                  <td class="py-3">
                    <div class="cbView font-medium text-gray-900">Membership fee</div>

                    <div class="cbEdit hidden">
                      <input class="w-full border rounded-lg px-2 py-1 text-sm bg-white disabled:bg-gray-50 disabled:text-gray-500" value="Membership fee">
                      <div class="mt-2 flex items-center gap-2">
                        <label class="text-xs text-gray-500">Amount</label>
                        <input class="w-32 border rounded-lg px-2 py-1 text-sm text-right bg-white disabled:bg-gray-50 disabled:text-gray-500" value="5000.05">
                      </div>
                    </div>
                  </td>
                  <td class="py-3 text-right text-gray-700">—</td>
                  <td class="py-3 text-right font-semibold text-gray-900">CHF 5’000.05</td>
                  <td class="cbEdit hidden py-3 text-right">
                    <button class="text-sm text-gray-600 hover:text-gray-900" onclick="toast('Remove item (dummy)')">Remove</button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Totals (right aligned, compact) -->
          <div class="mt-6 flex justify-end">
            <div class="w-full max-w-sm text-sm">
              <div class="flex items-center justify-between py-1">
                <span class="text-gray-600">Subtotal</span>
                <span class="font-medium text-gray-900" id="tSubtotal">CHF 5’000.05</span>
              </div>
              <div class="flex items-center justify-between py-1">
                <span class="text-gray-600">Tax <span class="text-[11px] text-gray-500">(5%)</span></span>
                <span class="font-medium text-gray-900" id="tTax">CHF 6.88</span>
              </div>
              <div class="flex items-center justify-between py-1">
                <span class="text-gray-600">Transaction costs</span>
                <span class="font-medium text-gray-900" id="tTx">CHF 8.99</span>
              </div>
              <div class="flex items-center justify-between pt-3 mt-2 border-t">
                <span class="text-gray-900 font-semibold">Total</span>
                <span class="text-gray-900 font-semibold" id="tTotal">CHF 5’015.92</span>
              </div>

              <div class="mt-3 text-[11px] text-gray-500" id="tFlowHint">
                Installment 1/3 (connected to a plan)
              </div>
            </div>
          </div>
        </section>

        <!-- Payments / Transactions (light in view, full in edit) -->
        <section class="border-t pt-8">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-xs font-semibold text-gray-800">Payments & events</div>
              <div class="text-[11px] text-gray-500 mt-1">View mode shows a compact summary. Edit mode shows the full list.</div>
            </div>
            <div class="flex items-center gap-2">
              <button class="px-3 py-2 text-sm rounded-lg border bg-white hover:bg-gray-50" onclick="toast('Add payment (dummy)')">Add payment</button>
              <button class="px-3 py-2 text-sm rounded-lg border bg-white hover:bg-gray-50" onclick="toast('Refund (dummy)')">Refund</button>
            </div>
          </div>

          <!-- Compact summary -->
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
            <div class="border rounded-lg px-3 py-2 bg-white flex items-center justify-between">
              <span class="text-gray-600">Paid</span>
              <span class="font-semibold text-gray-900" id="pPaid">CHF 0.00</span>
            </div>
            <div class="border rounded-lg px-3 py-2 bg-white flex items-center justify-between">
              <span class="text-gray-600">Open</span>
              <span class="font-semibold text-gray-900" id="pOpen">CHF 5’015.92</span>
            </div>
            <div class="border rounded-lg px-3 py-2 bg-white flex items-center justify-between">
              <span class="text-gray-600">Last activity</span>
              <span class="font-medium text-gray-900" id="pLast">—</span>
            </div>
          </div>

          <!-- View: collapsed list -->
          <div class="cbView mt-4">
            <button class="text-sm text-blue-700 hover:text-blue-800" onclick="toggleTx(true)">Show all transactions</button>
          </div>

          <!-- Full list (always visible in edit; expandable in view) -->
          <div id="txWrap" class="mt-4 hidden">
            <div class="overflow-hidden">
              <table class="w-full text-sm">
                <thead class="text-xs text-gray-500 border-b">
                  <tr>
                    <th class="text-left py-2 font-medium">Date</th>
                    <th class="text-left py-2 font-medium">Type</th>
                    <th class="text-left py-2 font-medium">Method</th>
                    <th class="text-right py-2 font-medium">Amount</th>
                    <th class="text-left py-2 font-medium">Status</th>
                    <th class="text-right py-2 font-medium">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y" id="txRows"></tbody>
              </table>
            </div>

            <div class="mt-3 text-[11px] text-gray-500">
              If a transaction was wrong, create a compensation entry (don’t edit/delete existing ones).
            </div>

            <div class="cbView mt-4">
              <button class="text-sm text-gray-600 hover:text-gray-900" onclick="toggleTx(false)">Hide</button>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>

  <!-- Schedule overlay (installments/subscription) -->
  <div id="scheduleOverlay" class="fixed inset-0 hidden items-center justify-center bg-black/40 p-4 z-50">
    <div class="w-full max-w-3xl bg-white rounded-2xl shadow-xl border overflow-hidden">
      <div class="px-5 py-4 border-b flex items-center justify-between">
        <div>
          <div class="text-sm font-semibold text-gray-900">Schedule</div>
          <div class="text-[11px] text-gray-500 mt-1" id="scheduleSubtitle">—</div>
        </div>
        <button class="px-3 py-2 text-sm rounded-lg border bg-white hover:bg-gray-50" onclick="closeSchedule()">Close</button>
      </div>
      <div class="p-5">
        <div class="overflow-hidden">
          <table class="w-full text-sm">
            <thead class="text-xs text-gray-500 border-b">
              <tr>
                <th class="text-left py-2 font-medium">#</th>
                <th class="text-left py-2 font-medium">Invoice ID</th>
                <th class="text-left py-2 font-medium">Invoice date</th>
                <th class="text-right py-2 font-medium">Amount</th>
                <th class="text-left py-2 font-medium">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y" id="scheduleRows"></tbody>
          </table>
        </div>
        <div class="mt-4 text-[11px] text-gray-500">
          Edits to shared fields should apply to future invoices only (never rewrite past invoices).
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-5 right-5 hidden z-[60]">
    <div class="bg-gray-900 text-white text-sm px-4 py-3 rounded-xl shadow-lg" id="toastMsg">Done</div>
  </div>

<script>
  // -------------------------
  // State + demo data
  // -------------------------
  const UI = { mode: 'view', flow: 'inst', status: 'open' };

  const money = (v) => {
    // Swiss-ish grouping for nicer look in prototype
    const n = Number(v);
    const parts = n.toFixed(2).split('.');
    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, "’");
    return `CHF ${parts.join('.')}`;
  };

  const STATUS = {
    open:      { label:'Open',          badge:'yellow', paid:0,     open:5015.92, hint:null, locks:{ all:false, pay:false, bill:false, items:false }, sepa:false },
    partial:   { label:'Partially paid',badge:'yellow', paid:125,   open:4890.92, hint:'Transactions exist. Some fields are locked.', locks:{ all:false, pay:true,  bill:false, items:true  }, sepa:false },
    paid:      { label:'Paid',          badge:'green',  paid:5015.92,open:0,      hint:'This invoice is paid. Editing is disabled.', locks:{ all:true,  pay:true,  bill:true,  items:true  }, sepa:false },
    sepa:      { label:'In SEPA file',  badge:'indigo', paid:0,     open:5015.92, hint:'This invoice is included in a generated SEPA file. Editing may create mismatches.', locks:{ all:false, pay:true, bill:false, items:true }, sepa:true },
    refunded:  { label:'Refunded',      badge:'gray',   paid:0,     open:0,       hint:'Refunded invoices are locked. Create corrections if needed.', locks:{ all:true,  pay:true,  bill:true,  items:true  }, sepa:false },
    cancelled: { label:'Cancelled',     badge:'gray',   paid:0,     open:0,       hint:'Cancelled invoices are locked.', locks:{ all:true,  pay:true,  bill:true,  items:true  }, sepa:false },
  };

  const FLOW = {
    once: { meta:'Once off', showSchedule:false, flowHint:'Once off (single invoice)' },
    inst: { meta:'Installment 1/3', showSchedule:true, flowHint:'Installment 1/3 (connected to a plan)' },
    sub:  { meta:'Subscription invoice', showSchedule:true, flowHint:'Subscription invoice (connected to a subscription)' },
  };

  const SCHEDULE = {
    inst: [
      { n:1, id:'COACH-00000386-1', date:'10.12.2025', amount:5015.92, status:'Open', current:true },
      { n:2, id:'COACH-00000386-2', date:'10.01.2026', amount:5015.92, status:'Planned', current:false },
      { n:3, id:'COACH-00000386-3', date:'10.02.2026', amount:5015.92, status:'Planned', current:false },
    ],
    sub: [
      { n:0, id:'COACH-00000386-INIT', date:'10.12.2025', amount:50.00, status:'Paid', current:false },
      { n:1, id:'COACH-00000386-SUB-1', date:'01.01.2026', amount:20.00, status:'Open', current:true },
      { n:2, id:'COACH-00000386-SUB-2', date:'01.02.2026', amount:20.00, status:'Planned', current:false },
    ]
  };

  function toast(msg){
    const t = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    t.classList.remove('hidden');
    setTimeout(() => t.classList.add('hidden'), 2200);
  }

  // -------------------------
  // Mode / flow / status
  // -------------------------
  function setMode(m){
    UI.mode = m;
    const isEdit = m === 'edit';

    document.getElementById('btnView').className =
      "px-3 py-2 text-sm rounded-lg " + (!isEdit ? "bg-white shadow-sm border border-gray-200" : "text-gray-700 hover:bg-white/60");
    document.getElementById('btnEdit').className =
      "px-3 py-2 text-sm rounded-lg " + (isEdit ? "bg-white shadow-sm border border-gray-200" : "text-gray-700 hover:bg-white/60");

    document.getElementById('btnSave').classList.toggle('hidden', !isEdit);
    document.getElementById('btnCancel').classList.toggle('hidden', !isEdit);

    document.querySelectorAll('.cbView').forEach(el => el.classList.toggle('hidden', isEdit));
    document.querySelectorAll('.cbEdit').forEach(el => el.classList.toggle('hidden', !isEdit));

    // tx list: in edit mode always open; in view mode collapsed
    if (isEdit) {
      document.getElementById('txWrap').classList.remove('hidden');
    } else {
      document.getElementById('txWrap').classList.add('hidden');
    }

    syncAll();
  }

  function setFlow(v){ UI.flow = v; syncAll(); }
  function setStatus(v){ UI.status = v; syncAll(); }

  // -------------------------
  // Payment method change (scope)
  // -------------------------
  function onPayMethodChanged(){
    // show apply scope only for connected flows
    const wrap = document.getElementById('applyScopeWrap');
    wrap.classList.toggle('hidden', !(UI.flow === 'inst' || UI.flow === 'sub'));
  }

  // -------------------------
  // Transactions (demo)
  // -------------------------
  function txForStatus(statusKey){
    if (statusKey === 'partial'){
      return [
        { date:'05.01.2026', type:'Payment', method:'Bank transfer', amount:+125.00, status:'Completed' },
      ];
    }
    if (statusKey === 'paid'){
      return [
        { date:'05.01.2026', type:'Payment', method:'Bank transfer', amount:+5015.92, status:'Completed' },
      ];
    }
    if (statusKey === 'sepa'){
      return [
        { date:'10.12.2025', type:'Collection', method:'SEPA', amount:+5015.92, status:'In export file' },
      ];
    }
    if (statusKey === 'refunded'){
      return [
        { date:'05.01.2026', type:'Payment', method:'Bank transfer', amount:+5015.92, status:'Completed' },
        { date:'10.01.2026', type:'Refund', method:'Bank transfer', amount:-5015.92, status:'Completed' },
      ];
    }
    return [];
  }

  function renderTx(){
    const tx = txForStatus(UI.status);
    const rows = document.getElementById('txRows');
    rows.innerHTML = '';

    const last = document.getElementById('pLast');
    last.textContent = tx.length ? `${tx[tx.length-1].type} · ${tx[tx.length-1].date}` : '—';

    if (!tx.length){
      rows.innerHTML = `<tr><td colspan="6" class="py-6 text-center text-sm text-gray-500">No transactions yet.</td></tr>`;
      return;
    }

    tx.forEach(t => {
      const tr = document.createElement('tr');
      const amtCls = t.amount < 0 ? 'text-rose-700' : 'text-gray-900';
      tr.innerHTML = `
        <td class="py-3 text-gray-700">${t.date}</td>
        <td class="py-3 font-medium text-gray-900">${t.type}</td>
        <td class="py-3 text-gray-700">${t.method}</td>
        <td class="py-3 text-right font-semibold ${amtCls}">${t.amount < 0 ? '– ' : ''}${money(Math.abs(t.amount))}</td>
        <td class="py-3">
          <span class="text-[11px] px-2.5 py-1 rounded-full bg-gray-100 text-gray-700 font-medium">${t.status}</span>
        </td>
        <td class="py-3 text-right">
          <button class="text-sm text-gray-600 hover:text-gray-900" onclick="toast('View transaction (dummy)')">View</button>
          <span class="text-gray-300 mx-2">|</span>
          <button class="text-sm text-gray-600 hover:text-gray-900" onclick="toast('Create correction (dummy)')">Correct</button>
        </td>
      `;
      rows.appendChild(tr);
    });
  }

  function toggleTx(show){
    if (UI.mode !== 'view') return;
    document.getElementById('txWrap').classList.toggle('hidden', !show);
  }

  // -------------------------
  // Schedule overlay
  // -------------------------
  function openSchedule(){
    const overlay = document.getElementById('scheduleOverlay');
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');

    const subtitle = document.getElementById('scheduleSubtitle');
    subtitle.textContent = UI.flow === 'inst' ? 'Installment plan (3 invoices)' : 'Subscription (recurring invoices)';

    const list = (UI.flow === 'inst') ? SCHEDULE.inst : SCHEDULE.sub;
    const tbody = document.getElementById('scheduleRows');
    tbody.innerHTML = '';

    list.forEach(r => {
      const tr = document.createElement('tr');
      const badge =
        r.status === 'Paid' ? 'bg-emerald-50 text-emerald-700' :
        r.status === 'Open' ? 'bg-yellow-50 text-yellow-700' :
        'bg-gray-100 text-gray-700';

      tr.innerHTML = `
        <td class="py-3 text-gray-700">${r.n}</td>
        <td class="py-3 font-medium text-gray-900">
          ${r.id}
          ${r.current ? `<span class="ml-2 text-[11px] px-2 py-0.5 rounded-full bg-gray-900 text-white font-medium">Current</span>` : ``}
        </td>
        <td class="py-3 text-gray-700">${r.date}</td>
        <td class="py-3 text-right font-semibold text-gray-900">${money(r.amount)}</td>
        <td class="py-3"><span class="text-[11px] px-2.5 py-1 rounded-full font-medium ${badge}">${r.status}</span></td>
      `;
      tbody.appendChild(tr);
    });
  }

  function closeSchedule(){
    const overlay = document.getElementById('scheduleOverlay');
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
  }

  // -------------------------
  // Sync UI
  // -------------------------
  function setStatusBadge(rule){
    const el = document.getElementById('hStatusBadge');
    el.textContent = rule.label;
    el.className = "inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-medium " +
      (rule.badge === 'yellow' ? "bg-yellow-50 text-yellow-700" :
       rule.badge === 'green'  ? "bg-emerald-50 text-emerald-700" :
       rule.badge === 'indigo' ? "bg-indigo-50 text-indigo-700" :
       "bg-gray-100 text-gray-700");
  }

  function syncHints(rule){
    const hint = document.getElementById('headerHint');
    if (!rule.hint){
      hint.classList.add('hidden');
      return;
    }
    hint.classList.remove('hidden');
    document.getElementById('headerHintTitle').textContent = rule.sepa ? 'SEPA file generated' : (rule.locks.all ? 'Editing disabled' : 'Limited editing');
    document.getElementById('headerHintText').textContent = rule.hint;
  }

  function lockFields(rule){
    // In edit mode: disable fields based on locks
    const isEdit = UI.mode === 'edit';

    const disable = (id, on) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.disabled = on;
    };

    // all locked means everything disabled
    const allLocked = rule.locks.all;

    disable('eRecipientName', !isEdit || allLocked || rule.locks.bill);
    disable('eRecipientAddress', !isEdit || allLocked || rule.locks.bill);
    disable('eMemberId', !isEdit || allLocked || rule.locks.bill);

    disable('eBillName', !isEdit || allLocked || rule.locks.bill);
    disable('eBillEmails', !isEdit || allLocked || rule.locks.bill);

    disable('ePayMethod', !isEdit || allLocked || rule.locks.pay);
    disable('eApplyScope', !isEdit || allLocked || rule.locks.pay);

    disable('eReference', !isEdit || allLocked); // keep optional

    // show/hide pay lock hint
    document.getElementById('payLockHint').classList.toggle('hidden', !isEdit || (!rule.locks.pay && !rule.sepa));

    // apply scope only relevant for connected flows
    if (isEdit){
      onPayMethodChanged();
    } else {
      document.getElementById('applyScopeWrap').classList.add('hidden');
    }
  }

  function syncBillingWarn(){
    if (UI.mode !== 'edit') {
      document.getElementById('billWarn').classList.add('hidden');
      return;
    }
    const emails = (document.getElementById('eBillEmails')?.value || '').trim();
    document.getElementById('billWarn').classList.toggle('hidden', emails.length > 0);
  }

  function syncPaymentView(){
    const map = { bank:'Bank transfer', sepa:'SEPA direct debit', cash:'Cash', psp:'Card / PSP' };
    const val = document.getElementById('ePayMethod')?.value || 'bank';
    document.getElementById('vPayMethod').textContent = map[val] || '—';
  }

  function syncHeader(flowMeta, rule){
    document.getElementById('hFlowMeta').textContent = flowMeta.meta;
    document.getElementById('btnViewSchedule').classList.toggle('hidden', !flowMeta.showSchedule);

    setStatusBadge(rule);
    document.getElementById('hTotal').textContent = money(5015.92);
    document.getElementById('hPaid').textContent = money(rule.paid);
    document.getElementById('hOpen').textContent = money(rule.open);

    document.getElementById('pPaid').textContent = money(rule.paid);
    document.getElementById('pOpen').textContent = money(rule.open);

    document.getElementById('tFlowHint').textContent = flowMeta.flowHint;
  }

  function syncAll(){
    const rule = STATUS[UI.status];
    const flowMeta = FLOW[UI.flow];

    syncHeader(flowMeta, rule);
    syncHints(rule);
    lockFields(rule);

    // connected flow shows schedule link (already)
    // payment method view label
    syncPaymentView();

    // totals (kept constant in prototype, but you can wire)
    document.getElementById('tSubtotal').textContent = money(5000.05);
    document.getElementById('tTax').textContent = money(6.88);
    document.getElementById('tTx').textContent = money(8.99);
    document.getElementById('tTotal').textContent = money(5015.92);

    // tx
    renderTx();

    // billing warn
    syncBillingWarn();
  }

  // -------------------------
  // Init
  // -------------------------
  function init(){
    // hook inputs
    document.getElementById('eBillEmails')?.addEventListener('input', syncBillingWarn);

    // set defaults
    setMode('view');
    setFlow(document.getElementById('demoFlow').value);
    setStatus(document.getElementById('demoStatus').value);
    syncAll();
  }
  init();
</script>
</body>
</html>
