  <script>
    // ---------- Wizard navigation ----------
    const stepBtns = [...document.querySelectorAll(".stepBtn")];
    const stepPanels = [...document.querySelectorAll(".stepPanel")];

    function setStep(n) {
      stepPanels.forEach(p => p.classList.add("hidden"));
      const panel = document.getElementById(`step-${n}`);
      if (panel) panel.classList.remove("hidden");

      stepBtns.forEach(btn => {
        const isActive = btn.dataset.step === String(n);
        btn.classList.toggle("border-slate-300", isActive);
        btn.classList.toggle("border-slate-200", !isActive);
        const dot = btn.querySelector(".dot");
        if (dot) {
          dot.classList.toggle("bg-slate-900", isActive);
          dot.classList.toggle("text-white", isActive);
          dot.classList.toggle("bg-slate-200", !isActive);
          dot.classList.toggle("text-slate-700", !isActive);
        }
      });

      // ensure preview stays in sync when arriving at invoices step
      if (String(n) === "5") recalc();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    stepBtns.forEach(btn => btn.addEventListener("click", () => setStep(btn.dataset.step)));
    document.querySelectorAll(".nextBtn").forEach(b => b.addEventListener("click", () => setStep(b.dataset.next)));
    document.querySelectorAll(".prevBtn").forEach(b => b.addEventListener("click", () => setStep(b.dataset.prev)));
    setStep(1);

    // ---------- Modal helpers ----------
    const backdrop = document.getElementById('backdrop');
    function openModal(id){
      backdrop.classList.remove('hidden');
      document.getElementById(id).classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    }
    function closeAll(){
      backdrop.classList.add('hidden');
      document.querySelectorAll('[id^="modal-"]').forEach(m => m.classList.add('hidden'));
      document.body.classList.remove('overflow-hidden');
    }

    // ---------- Service year -> service period text ----------
    const serviceYear = document.getElementById('serviceYear');
    const servicePeriodText = document.getElementById('servicePeriodText');
    const boxService = document.getElementById('boxService');
    const sumService = document.getElementById('sumService');
    const invServiceRange = document.getElementById('invServiceRange');

    function updateServicePeriod() {
      const y = serviceYear.value;
      const txt = `01.01.${y} – 31.12.${y}`;
      servicePeriodText.textContent = txt;
      boxService.textContent = txt;
      sumService.textContent = `Service: ${y} (01.01–31.12)`;
      invServiceRange.textContent = txt;
      recalc();
    }
    serviceYear.addEventListener('change', updateServicePeriod);

    // ---------- Payment type selection ----------
    let payType = "inst"; // default
    const payBtns = [...document.querySelectorAll(".payType")];
    const sumPay = document.getElementById('sumPay');

    function setPayType(t){
      payType = t;
      payBtns.forEach(b => {
        const active = b.dataset.type === t;
        b.classList.toggle("border-slate-900", active);
        b.classList.toggle("ring-2", active);
        b.classList.toggle("ring-slate-200", active);
      });
      recalc();
    }
    payBtns.forEach(b => b.addEventListener('click', () => setPayType(b.dataset.type)));
    setPayType("inst");

    // ---------- Assignment date / proration calc ----------
    const assignStart = document.getElementById('assignStart');
    const assignEnd = document.getElementById('assignEnd');
    const enableProration = document.getElementById('enableProration');

    const boxActive = document.getElementById('boxActive');
    const boxMonths = document.getElementById('boxMonths');
    const boxFactor = document.getElementById('boxFactor');

    const sumDates = document.getElementById('sumDates');
    const sumProration = document.getElementById('sumProration');

    function monthName(i){
      return ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][i];
    }

    function clampToService(dateStr, year){
      // service is calendar year
      const s = new Date(`${year}-01-01T00:00:00`);
      const e = new Date(`${year}-12-31T00:00:00`);
      const d = new Date(`${dateStr}T00:00:00`);
      if (d < s) return s;
      if (d > e) return e;
      return d;
    }

    function countProrationMonths(startDate, endDate, year){
      // MVP monthly proration:
      // - include month of start
      // - include month of end
      // Both clamped to service year
      const s = clampToService(startDate, year);
      const e = endDate ? clampToService(endDate, year) : new Date(`${year}-12-31T00:00:00`);
      const sm = s.getMonth();
      const em = e.getMonth();
      const months = (em - sm) + 1;
      return { months: Math.max(0, months), sm, em };
    }

    // ---------- Invoice preview generation ----------
    const invoiceRows = document.getElementById('invoiceRows');
    const invBillingTitle = document.getElementById('invBillingTitle');
    const invBillingRange = document.getElementById('invBillingRange');
    const liMeta = document.getElementById('liMeta');
    const liAmount = document.getElementById('liAmount');
    const liCalc = document.getElementById('liCalc');
    const invTotal = document.getElementById('invTotal');
    const invStatus = document.getElementById('invStatus');
    const genHint = document.getElementById('genHint');

    let paidFirst = false;

    function money(n){
      return `CHF ${n.toFixed(2)}`;
    }

    function recalc(){
      const y = Number(serviceYear.value);
      const start = assignStart.value;
      const end = assignEnd.value;

      // summary dates
      sumDates.textContent = `Start: ${start ? start.split('-').reverse().join('.') : '—'} · End: ${end ? end.split('-').reverse().join('.') : '—'}`;

      // monthly proration months inside service period
      const pr = countProrationMonths(start, end, y);
      const months = pr.months;
      const factor = months / 12;

      const activeLabel = months === 0 ? "—" : `${monthName(pr.sm)} – ${monthName(pr.em)} ${y}`;
      boxActive.textContent = activeLabel;
      boxMonths.textContent = `${months}/12 months`;
      boxFactor.textContent = factor.toFixed(4);

      const prOn = enableProration.checked;
      sumProration.textContent = `Proration: ${prOn ? 'ON' : 'OFF'} · Months: ${months}/12`;

      // Billing start preview (simplified)
      const billRule = document.getElementById('billRule').value;
      const billDate = document.getElementById('billDate').value;
      let firstCharge = billDate;
      if (billRule.includes("Same day")) firstCharge = start;
      if (billRule.includes("1st of next month")) {
        const d = new Date(`${start}T00:00:00`);
        d.setMonth(d.getMonth() + 1);
        d.setDate(1);
        firstCharge = d.toISOString().slice(0,10);
      }
      if (billRule.includes("Service period start")) firstCharge = `${y}-01-01`;
      sumPay.textContent =
        (payType === "once" ? "Once-off" : payType === "inst" ? "Installments" : "Subscription") +
        ` · First charge: ${firstCharge ? firstCharge.split('-').reverse().join('.') : '—'}`;

      // Amount logic (demo numbers)
      // Base annual = 120
      const annual = 120;
      const effectiveAnnual = prOn ? annual * factor : annual;

      // Build invoices list
      invoiceRows.innerHTML = "";
      const rows = [];

      if (payType === "once"){
        // one invoice for effectiveAnnual
        rows.push({
          inv: "INV-0001",
          service: `Membership ${y}`,
          billing: "Once-off",
          due: firstCharge,
          amount: effectiveAnnual,
          status: paidFirst ? "paid" : "open"
        });
        genHint.textContent = "Once-off: one invoice for the (prorated) annual amount.";
        invBillingTitle.textContent = "Once-off";
        invBillingRange.textContent = `Due: ${firstCharge}`;
      }

      if (payType === "inst"){
        // installments across active months (MVP):
        // if proration ON: create invoices for active months only
        // else: create 12 invoices
        const count = prOn ? months : 12;
        const startMonth = prOn ? pr.sm : 0;
        const per = count > 0 ? (effectiveAnnual / count) : 0;

        for (let i=0;i<count;i++){
          const m = startMonth + i;
          const ym = y;
          const label = `${monthName(m)} ${ym}`;
          // due date: 1st of that month (simplified)
          const due = `${ym}-${String(m+1).padStart(2,'0')}-01`;
          rows.push({
            inv: `INV-${String(i+1).padStart(4,'0')}`,
            service: `Membership ${y}`,
            billing: `Installment ${i+1}/${count} · ${label}`,
            due,
            amount: per,
            status: (paidFirst && i===0) ? "paid" : "open"
          });
        }
        genHint.textContent = prOn
          ? "Installments with proration: invoices only for the active months inside the year."
          : "Installments without proration: 12 invoices for the full year.";
        invBillingTitle.textContent = count ? `Installment 1/${count}` : "Installments";
        invBillingRange.textContent = count ? `Period: ${monthName(startMonth)} ${y}` : "—";
      }

      if (payType === "sub"){
        // For fixed-period + subscription:
        // we show as monthly charges until period end (or until assignment end)
        // similar to installments, but conceptually "subscription instance"
        const count = prOn ? months : 12;
        const startMonth = prOn ? pr.sm : 0;
        const per = count > 0 ? (effectiveAnnual / count) : 0;

        for (let i=0;i<count;i++){
          const m = startMonth + i;
          const label = `${monthName(m)} ${y}`;
          const due = `${y}-${String(m+1).padStart(2,'0')}-01`;
          rows.push({
            inv: `INV-${String(i+1).padStart(4,'0')}`,
            service: `Membership ${y}`,
            billing: `Subscription charge · ${label}`,
            due,
            amount: per,
            status: (paidFirst && i===0) ? "paid" : "open"
          });
        }
        genHint.textContent =
          "Subscription behind a fixed-period contribution: monthly charges until service period end (or assignment end). " +
          "If you want true never-ending subscriptions, use Rolling service mode instead.";
        invBillingTitle.textContent = count ? `Subscription charge · ${monthName(startMonth)} ${y}` : "Subscription";
        invBillingRange.textContent = count ? `Period: ${monthName(startMonth)} ${y}` : "—";
      }

      // Render rows
      rows.forEach(r => {
        const statusBadge = r.status === "paid"
          ? `<span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2 py-1 text-xs text-emerald-700">paid</span>`
          : `<span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-2 py-1 text-xs text-slate-600">open</span>`;
        const dueNice = r.due ? r.due.split('-').reverse().join('.') : "—";

        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td class="py-2 pr-3 font-medium">${r.inv}</td>
          <td class="py-2 pr-3 text-slate-700">${r.service}</td>
          <td class="py-2 pr-3 text-slate-700">${r.billing}</td>
          <td class="py-2 pr-3 text-slate-700">${dueNice}</td>
          <td class="py-2 pr-3 text-right font-medium">${money(r.amount)}</td>
          <td class="py-2 text-right">${statusBadge}</td>
        `;
        invoiceRows.appendChild(tr);
      });

      // Show first invoice details in header preview
      const first = rows[0] || null;
      if (first){
        liMeta.textContent = `Service: 01.01.${y}–31.12.${y} · Assignment active: ${activeLabel} (${months}/12)`;
        liAmount.textContent = money(first.amount);
        liCalc.textContent = prOn ? `Proration ${months}/12 applied` : "No proration applied";
        invTotal.textContent = `Total: ${money(first.amount)}`;
        invStatus.textContent = `Status: ${first.status}`;
      } else {
        liMeta.textContent = "—";
        liAmount.textContent = money(0);
        liCalc.textContent = "—";
        invTotal.textContent = `Total: ${money(0)}`;
        invStatus.textContent = "Status: —";
      }
    }

    assignStart.addEventListener('change', () => { recalc(); });
    assignEnd.addEventListener('change', () => { recalc(); });
    enableProration.addEventListener('change', () => { recalc(); });

    document.getElementById('billRule').addEventListener('change', recalc);
    document.getElementById('billDate').addEventListener('change', recalc);

    function simulatePaid(){
      paidFirst = !paidFirst;
      recalc();
    }

    // init
    updateServicePeriod();
    recalc();

    // Save demo
    document.getElementById('btnCreate').addEventListener('click', () => alert('Prototype: create FeeAssignment + (optional) invoices'));
    document.getElementById('btnSaveTop').addEventListener('click', () => alert('Prototype: save'));
  </script>
