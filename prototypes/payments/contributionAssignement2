<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CoachBetter – Contribution / Fee Assignment Walkthrough (Fixed period, all payment types)</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .cb-scroll::-webkit-scrollbar { height: 10px; width: 10px; }
    .cb-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 999px; }
    .cb-scroll::-webkit-scrollbar-track { background: transparent; }
  </style>
</head>

<body class="bg-slate-50 text-slate-900">
  <!-- Top bar -->
  <div class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
    <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <button class="h-9 w-9 rounded-full border border-slate-200 bg-white hover:bg-slate-50 grid place-items-center">
          <span class="text-lg leading-none">←</span>
        </button>
        <div>
          <div class="text-sm font-semibold">Assign contribution / fee</div>
          <div class="text-xs text-slate-500">Walkthrough · Fixed period (Calendar year) · once-off / installments / subscription</div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm hover:bg-slate-50">Cancel</button>
        <button id="btnSaveTop" class="rounded-full bg-emerald-500 px-4 py-2 text-sm text-white hover:bg-emerald-600">Save</button>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-6xl px-4 py-6">
    <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden">
      <!-- Stepper -->
      <div class="border-b border-slate-200 bg-slate-50">
        <div class="px-4 sm:px-6 py-4 flex flex-wrap items-center justify-between gap-3">
          <div>
            <div class="text-sm font-semibold">Fee assignment</div>
            <div class="text-xs text-slate-500">Person → Contribution → Dates → Payment option → Invoice preview → Confirm</div>
          </div>
          <div class="text-xs text-slate-600 rounded-full border border-slate-200 bg-white px-3 py-1">
            Membership is NOT coupled – assignment has its own start/end dates
          </div>
        </div>

        <div class="px-4 sm:px-6 pb-4">
          <div class="grid grid-cols-1 sm:grid-cols-6 gap-2">
            <button data-step="1" class="stepBtn rounded-xl border border-slate-300 bg-white px-3 py-2 text-left hover:bg-slate-50">
              <div class="flex items-start gap-2">
                <div class="dot mt-0.5 h-5 w-5 rounded-full bg-slate-900 text-white text-xs grid place-items-center">1</div>
                <div>
                  <div class="text-sm font-semibold">Person</div>
                  <div class="text-xs text-slate-500">Who pays</div>
                </div>
              </div>
            </button>

            <button data-step="2" class="stepBtn rounded-xl border border-slate-200 bg-white px-3 py-2 text-left hover:bg-slate-50">
              <div class="flex items-start gap-2">
                <div class="dot mt-0.5 h-5 w-5 rounded-full bg-slate-200 text-slate-700 text-xs grid place-items-center">2</div>
                <div>
                  <div class="text-sm font-semibold">Contribution</div>
                  <div class="text-xs text-slate-500">Product + service</div>
                </div>
              </div>
            </button>

            <button data-step="3" class="stepBtn rounded-xl border border-slate-200 bg-white px-3 py-2 text-left hover:bg-slate-50">
              <div class="flex items-start gap-2">
                <div class="dot mt-0.5 h-5 w-5 rounded-full bg-slate-200 text-slate-700 text-xs grid place-items-center">3</div>
                <div>
                  <div class="text-sm font-semibold">Dates</div>
                  <div class="text-xs text-slate-500">Start/end</div>
                </div>
              </div>
            </button>

            <button data-step="4" class="stepBtn rounded-xl border border-slate-200 bg-white px-3 py-2 text-left hover:bg-slate-50">
              <div class="flex items-start gap-2">
                <div class="dot mt-0.5 h-5 w-5 rounded-full bg-slate-200 text-slate-700 text-xs grid place-items-center">4</div>
                <div>
                  <div class="text-sm font-semibold">Payment</div>
                  <div class="text-xs text-slate-500">Option + start</div>
                </div>
              </div>
            </button>

            <button data-step="5" class="stepBtn rounded-xl border border-slate-200 bg-white px-3 py-2 text-left hover:bg-slate-50">
              <div class="flex items-start gap-2">
                <div class="dot mt-0.5 h-5 w-5 rounded-full bg-slate-200 text-slate-700 text-xs grid place-items-center">5</div>
                <div>
                  <div class="text-sm font-semibold">Invoices</div>
                  <div class="text-xs text-slate-500">Preview</div>
                </div>
              </div>
            </button>

            <button data-step="6" class="stepBtn rounded-xl border border-slate-200 bg-white px-3 py-2 text-left hover:bg-slate-50">
              <div class="flex items-start gap-2">
                <div class="dot mt-0.5 h-5 w-5 rounded-full bg-slate-200 text-slate-700 text-xs grid place-items-center">6</div>
                <div>
                  <div class="text-sm font-semibold">Confirm</div>
                  <div class="text-xs text-slate-500">Create</div>
                </div>
              </div>
            </button>
          </div>
        </div>
      </div>

      <!-- Content grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12">
        <!-- Main -->
        <section class="lg:col-span-8 p-4 sm:p-6 space-y-6">
          <!-- STEP 1 -->
          <div id="step-1" class="stepPanel">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="text-lg font-semibold">Select person</div>
                <div class="mt-1 text-sm text-slate-500">Assign a contribution/fee to a club person (independent from membership).</div>
              </div>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">Existing concept</span>
            </div>

            <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <label class="text-sm font-medium">Search person</label>
                <input class="mt-2 w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm" placeholder="Type name…" value="Max Muster"/>
                <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-3">
                  <div class="text-sm font-semibold">Max Muster</div>
                  <div class="text-xs text-slate-500">Club person · Member ID: 12345 · Email: max@example.com</div>
                </div>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <div class="text-sm font-medium">Billing contact</div>
                <div class="mt-2 text-sm text-slate-700">Default: Person</div>
                <div class="mt-2 rounded-xl border border-slate-200 bg-slate-50 p-3 text-xs text-slate-600">
                  Later: allow selecting billing contact (parents/emails), same as your invoice recipient concept.
                </div>
              </div>
            </div>

            <div class="pt-2 flex justify-end">
              <button class="nextBtn rounded-full bg-slate-900 px-5 py-2 text-sm text-white hover:bg-slate-800" data-next="2">Next</button>
            </div>
          </div>

          <!-- STEP 2 -->
          <div id="step-2" class="stepPanel hidden">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="text-lg font-semibold">Select contribution</div>
                <div class="mt-1 text-sm text-slate-500">Fixed period example: Calendar year (service umbrella).</div>
              </div>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">DE-ready</span>
            </div>

            <div class="mt-5 grid grid-cols-1 gap-4">
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <label class="text-sm font-medium">Contribution (product)</label>
                <select id="productSelect" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm">
                  <option selected>Mitgliedsbeitrag (Template)</option>
                  <option>Abteilung Fussball Beitrag (Template)</option>
                  <option>Spenden-Abo</option>
                </select>

                <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-xs text-slate-500">Service description</div>
                      <div class="mt-1 text-sm font-semibold" id="serviceLabel">Calendar year (fixed) – 2026</div>
                      <div class="mt-1 text-xs text-slate-600">Proration: ON · Auto renew annually: ON</div>
                    </div>
                    <span class="rounded-full border border-slate-200 bg-white px-2 py-1 text-xs text-slate-600">from product</span>
                  </div>
                </div>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <div class="text-sm font-medium">Select service year</div>
                <div class="mt-1 text-sm text-slate-600">
                  In a fixed-period template, you pick the <span class="font-medium">year instance</span> for this assignment.
                </div>
                <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
                  <div>
                    <label class="text-sm font-medium">Year</label>
                    <select id="serviceYear" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm">
                      <option>2025</option>
                      <option selected>2026</option>
                      <option>2027</option>
                    </select>
                  </div>
                  <div class="sm:col-span-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs text-slate-600">
                    Service period will be: <span class="font-medium" id="servicePeriodText">01.01.2026 – 31.12.2026</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="pt-2 flex items-center justify-between">
              <button class="prevBtn rounded-full border border-slate-200 bg-white px-5 py-2 text-sm hover:bg-slate-50" data-prev="1">Back</button>
              <button class="nextBtn rounded-full bg-slate-900 px-5 py-2 text-sm text-white hover:bg-slate-800" data-next="3">Next</button>
            </div>
          </div>

          <!-- STEP 3 -->
          <div id="step-3" class="stepPanel hidden">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="text-lg font-semibold">Assignment dates (independent from membership)</div>
                <div class="mt-1 text-sm text-slate-500">
                  This is the key change for your system: fee assignment has its own start/end dates.
                </div>
              </div>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">New entity</span>
            </div>

            <div class="mt-5 grid grid-cols-1 gap-4">
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="text-sm font-medium">Assignment start date*</label>
                    <input id="assignStart" type="date" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm" value="2026-05-20">
                    <div class="mt-1 text-xs text-slate-500">
                      Example: joins late (20.05.2026)
                    </div>
                  </div>
                  <div>
                    <label class="text-sm font-medium">Assignment end date (optional)</label>
                    <input id="assignEnd" type="date" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm" value="">
                    <div class="mt-1 text-xs text-slate-500">
                      Set when leaving early. If empty: until service period end.
                    </div>
                  </div>
                </div>

                <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
                  <div class="text-sm font-medium">How late join / early leave is handled</div>
                  <div class="mt-1 text-sm text-slate-600">
                    Use <span class="font-medium">proration</span> rules to compute the chargeable portion inside the service period.
                    MVP: monthly proration based on assignment start/end month.
                  </div>
                  <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div class="rounded-xl border border-slate-200 bg-white p-3">
                      <div class="text-xs text-slate-500">Service period</div>
                      <div class="mt-1 text-sm font-semibold" id="boxService">01.01.2026 – 31.12.2026</div>
                    </div>
                    <div class="rounded-xl border border-slate-200 bg-white p-3">
                      <div class="text-xs text-slate-500">Assignment active in</div>
                      <div class="mt-1 text-sm font-semibold" id="boxActive">May – Dec 2026</div>
                      <div class="mt-1 text-xs text-slate-500" id="boxMonths">8/12 months</div>
                    </div>
                    <div class="rounded-xl border border-slate-200 bg-white p-3">
                      <div class="text-xs text-slate-500">Proration factor</div>
                      <div class="mt-1 text-sm font-semibold" id="boxFactor">0.6667</div>
                      <div class="mt-1 text-xs text-slate-500">Used in invoice amounts</div>
                    </div>
                  </div>
                </div>

                <label class="mt-4 flex items-start gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3">
                  <input id="enableProration" type="checkbox" class="mt-1 h-4 w-4" checked>
                  <div>
                    <div class="text-sm font-medium">Apply proration (recommended)</div>
                    <div class="text-xs text-slate-500">
                      If OFF, full year is charged even when joining late/leaving early.
                    </div>
                  </div>
                </label>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <div class="text-sm font-medium">Early leave example</div>
                <div class="mt-1 text-sm text-slate-600">Try setting end date to 2026-09-10 to see reduced months.</div>
                <div class="mt-3 flex gap-2 flex-wrap">
                  <button class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm hover:bg-slate-50" onclick="document.getElementById('assignEnd').value='2026-09-10'; recalc();">Set end: 10.09.2026</button>
                  <button class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm hover:bg-slate-50" onclick="document.getElementById('assignEnd').value=''; recalc();">Clear end date</button>
                </div>
              </div>
            </div>

            <div class="pt-2 flex items-center justify-between">
              <button class="prevBtn rounded-full border border-slate-200 bg-white px-5 py-2 text-sm hover:bg-slate-50" data-prev="2">Back</button>
              <button class="nextBtn rounded-full bg-slate-900 px-5 py-2 text-sm text-white hover:bg-slate-800" data-next="4">Next</button>
            </div>
          </div>

          <!-- STEP 4 -->
          <div id="step-4" class="stepPanel hidden">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="text-lg font-semibold">Payment option</div>
                <div class="mt-1 text-sm text-slate-500">Pick once-off / installments / subscription (behind the contribution).</div>
              </div>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">Existing options</span>
            </div>

            <div class="mt-5 grid grid-cols-1 gap-4">
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <label class="text-sm font-medium">Payment type</label>
                <div class="mt-2 grid grid-cols-1 sm:grid-cols-3 gap-3">
                  <button class="payType rounded-2xl border border-slate-200 bg-white p-4 text-left hover:bg-slate-50" data-type="once">
                    <div class="h-10 w-10 rounded-xl bg-slate-50 border border-slate-200 grid place-items-center">💳</div>
                    <div class="mt-3 font-semibold">Once-off</div>
                    <div class="mt-1 text-xs text-slate-500">One invoice</div>
                  </button>
                  <button class="payType rounded-2xl border border-slate-200 bg-white p-4 text-left hover:bg-slate-50" data-type="inst">
                    <div class="h-10 w-10 rounded-xl bg-slate-50 border border-slate-200 grid place-items-center">📦</div>
                    <div class="mt-3 font-semibold">Installments</div>
                    <div class="mt-1 text-xs text-slate-500">Multiple invoices</div>
                  </button>
                  <button class="payType rounded-2xl border border-slate-200 bg-white p-4 text-left hover:bg-slate-50" data-type="sub">
                    <div class="h-10 w-10 rounded-xl bg-slate-50 border border-slate-200 grid place-items-center">🔁</div>
                    <div class="mt-3 font-semibold">Subscription</div>
                    <div class="mt-1 text-xs text-slate-500">Until cancelled</div>
                  </button>
                </div>

                <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <div class="text-sm font-medium">Billing start</div>
                      <div class="text-xs text-slate-600">
                        Assignment has its own start date. Billing start can be <span class="font-medium">defaulted</span> from the option and overridden here.
                      </div>
                    </div>
                    <span class="rounded-full border border-slate-200 bg-white px-2 py-1 text-xs text-slate-600">Override</span>
                  </div>

                  <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div>
                      <label class="text-sm font-medium">First charge rule</label>
                      <select id="billRule" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm">
                        <option>Same day as assignment start</option>
                        <option selected>1st of next month</option>
                        <option>Service period start (01.01.YYYY)</option>
                        <option>Specific date</option>
                      </select>
                    </div>
                    <div>
                      <label class="text-sm font-medium">Specific date</label>
                      <input id="billDate" type="date" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm" value="2026-06-01">
                    </div>
                  </div>

                  <div class="mt-3 text-xs text-slate-600">
                    For fixed-period contributions in DE: most clubs use installments with first charge “next month 1st”.
                  </div>
                </div>

                <div class="mt-4 flex justify-end">
                  <button class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" onclick="openModal('modal-optionDetails')">
                    Edit selected option (existing popup)
                  </button>
                </div>
              </div>
            </div>

            <div class="pt-2 flex items-center justify-between">
              <button class="prevBtn rounded-full border border-slate-200 bg-white px-5 py-2 text-sm hover:bg-slate-50" data-prev="3">Back</button>
              <button class="nextBtn rounded-full bg-slate-900 px-5 py-2 text-sm text-white hover:bg-slate-800" data-next="5">Next</button>
            </div>
          </div>

          <!-- STEP 5 -->
          <div id="step-5" class="stepPanel hidden">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="text-lg font-semibold">Invoice preview</div>
                <div class="mt-1 text-sm text-slate-500">
                  What is on the invoice? Always show both: <span class="font-medium">Service period</span> + <span class="font-medium">Billing period / installment</span>.
                </div>
              </div>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">Key outcome</span>
            </div>

            <div class="mt-5 space-y-4">
              <!-- Invoice header preview -->
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <div class="text-sm font-semibold">Invoice (preview)</div>
                    <div class="mt-1 text-xs text-slate-500">This shows the minimum fields you need to add to invoices/line items.</div>
                  </div>
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600" id="invStatus">Status: open</span>
                </div>

                <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
                  <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                    <div class="text-xs text-slate-500">Recipient</div>
                    <div class="mt-1 text-sm font-semibold">Max Muster</div>
                    <div class="mt-1 text-xs text-slate-500">Member ID: 12345</div>
                  </div>

                  <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                    <div class="text-xs text-slate-500">Service</div>
                    <div class="mt-1 text-sm font-semibold" id="invService">Mitgliedschaft 2026</div>
                    <div class="mt-1 text-xs text-slate-600" id="invServiceRange">01.01.2026 – 31.12.2026</div>
                  </div>

                  <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                    <div class="text-xs text-slate-500">Billing</div>
                    <div class="mt-1 text-sm font-semibold" id="invBillingTitle">Installment 1/8</div>
                    <div class="mt-1 text-xs text-slate-600" id="invBillingRange">Period: Jun 2026</div>
                  </div>
                </div>

                <div class="mt-4 rounded-xl border border-slate-200 bg-white overflow-hidden">
                  <div class="px-4 py-3 border-b border-slate-100 text-sm font-semibold">Line items</div>
                  <div class="px-4 py-3 text-sm">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <div class="font-medium" id="liTitle">Mitgliedsbeitrag 2026</div>
                        <div class="text-xs text-slate-500" id="liMeta">
                          Service: 01.01.2026–31.12.2026 · Assignment active: May–Dec (8/12)
                        </div>
                      </div>
                      <div class="text-right">
                        <div class="font-semibold" id="liAmount">CHF 80.00</div>
                        <div class="text-xs text-slate-500" id="liCalc">Proration 8/12 applied</div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="mt-4 flex items-center justify-between">
                  <div class="text-xs text-slate-500">Tax and fees follow your existing rules (product/club level).</div>
                  <div class="text-sm font-semibold" id="invTotal">Total: CHF 80.00</div>
                </div>
              </div>

              <!-- Generated invoice list preview -->
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <div class="text-sm font-semibold">Invoices to create</div>
                    <div class="text-xs text-slate-500" id="genHint">Based on payment type + assignment dates.</div>
                  </div>
                  <div class="flex items-center gap-2">
                    <button class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm hover:bg-slate-50" onclick="simulatePaid()">Mark first as paid (demo)</button>
                    <button class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm hover:bg-slate-50" onclick="recalc()">Recalculate</button>
                  </div>
                </div>

                <div class="mt-4 overflow-auto cb-scroll">
                  <table class="min-w-full text-sm">
                    <thead class="text-xs text-slate-500">
                      <tr class="border-b border-slate-200">
                        <th class="py-2 pr-3 text-left font-medium">Invoice</th>
                        <th class="py-2 pr-3 text-left font-medium">Service</th>
                        <th class="py-2 pr-3 text-left font-medium">Billing period</th>
